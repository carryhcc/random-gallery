<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipeRefresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/page_padding_horizontal"
        android:paddingTop="@dimen/page_padding_top"
        android:paddingBottom="@dimen/page_padding_bottom">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_surface_card"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/card_padding_sm">

            <ImageButton
                android:id="@+id/btnBackHome"
                android:layout_width="@dimen/icon_size"
                android:layout_height="@dimen/icon_size"
                android:background="@drawable/bg_secondary_button"
                android:contentDescription="@string/back"
                android:padding="@dimen/spacing_sm"
                android:src="@drawable/ic_action_back"
                app:tint="@color/text_primary" />

            <TextView
                style="@style/TextSectionTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_md"
                android:layout_weight="1"
                android:text="@string/nav_label_random_pic" />

            <ImageButton
                android:id="@+id/btnRefresh"
                android:layout_width="@dimen/icon_size"
                android:layout_height="@dimen/icon_size"
                android:background="@drawable/bg_secondary_button"
                android:contentDescription="@string/refresh"
                android:padding="@dimen/spacing_sm"
                android:src="@drawable/ic_action_refresh"
                app:tint="@color/text_primary" />

            <Button
                android:id="@+id/btnDownload"
                style="@style/TextButton"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/button_height_sm"
                android:minHeight="@dimen/touch_target_min"
                android:layout_marginStart="@dimen/element_gap"
                android:background="@drawable/bg_primary_button"
                android:paddingHorizontal="@dimen/spacing_lg"
                android:text="@string/download"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Image area -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="@dimen/element_gap"
            android:layout_weight="1"
            android:background="@drawable/bg_surface_card"
            android:padding="@dimen/card_padding_sm">

            <ImageView
                android:id="@+id/image"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/image"
                android:scaleType="fitCenter" />

            <LinearLayout
                android:id="@+id/skeletonContainer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="@dimen/spacing_xl"
                android:visibility="gone">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/skeleton_height_small"
                    android:layout_marginHorizontal="@dimen/skeleton_margin_horizontal"
                    android:background="@drawable/bg_skeleton" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/skeleton_height_large"
                    android:layout_marginTop="@dimen/spacing_lg"
                    android:layout_marginHorizontal="@dimen/spacing_lg"
                    android:background="@drawable/bg_skeleton" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/skeleton_height_tiny"
                    android:layout_marginTop="@dimen/spacing_lg"
                    android:layout_marginHorizontal="@dimen/skeleton_margin_horizontal_wide"
                    android:background="@drawable/bg_skeleton" />
            </LinearLayout>
        </FrameLayout>

        <!-- Group name pill -->
        <TextView
            android:id="@+id/groupName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="@dimen/element_gap"
            android:background="@drawable/bg_secondary_button_base"
            android:paddingHorizontal="@dimen/spacing_lg"
            android:paddingVertical="@dimen/spacing_sm"
            android:text="@string/group_name_label"
            android:textColor="@color/primary_color"
            android:textSize="13sp"
            android:textStyle="bold" />

    </LinearLayout>

</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
